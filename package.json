{
  "name": "traceready",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "audit:public-dataset": "node --experimental-strip-types --no-warnings scripts/audit-public-dataset.mjs",
    "audit:outreach-routes": "node scripts/audit-outreach-routes.mjs",
    "init:outreach-results": "node scripts/init-outreach-results.mjs",
    "next:outreach": "node scripts/next-outreach-actions.mjs",
    "prepare:outreach": "node scripts/prepare-outreach-workspace.mjs",
    "render:outreach": "node scripts/render-outreach-pack.mjs",
    "render:outreach-day": "node scripts/render-outreach-day-pack.mjs",
    "render:outreach-replies": "node scripts/render-outreach-reply-playbook.mjs",
    "summarize:outreach": "node scripts/summarize-outreach-results.mjs",
    "update:outreach-result": "node scripts/update-outreach-result.mjs",
    "verify:outreach": "node scripts/verify-outreach.mjs",
    "verify:launch": "node scripts/verify-launch.mjs",
    "check": "npm run verify:outreach && npm run lint && npm run test && npm run build"
